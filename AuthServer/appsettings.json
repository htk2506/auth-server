{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8080"
      },
      "Https": {
        "Url": "https://0.0.0.0:4343"
      }
    }
  },
  "ConnectionStrings": {
    "Database": "<database connection string>"
  },
  "Jwt": {
    "SymmetricKey": "<Symmetric key>",
    "PrivateKey": "<RSA private key>",
    "PublicKey": "<RSA public key>",
    "Issuer": "<Issuer>",
    "Audience": "<Audience>",
    "SessionDays": 3
  }
}